# ==========================================
# 小易伴侣 - 环境变量配置示例
# ==========================================

# ==================== 方舟 Coding Plan 配置（优先使用）====================
# 火山引擎方舟 Coding Plan API (Pro 套餐)
# 获取地址: https://ark.cn-beijing.volces.com/
# 
# 【Pro 套餐配额】
# - 每5小时: 最多约 6,000 次请求
# - 每周: 最多约 45,000 次请求  
# - 每订阅月: 最多约 90,000 次请求
#
# 【可用模型】
# - ark-code-latest: 最新稳定版（推荐）
# - auto: Auto智能模式，自动选择最佳模型
# - deepseek-v3: DeepSeek V3 推理模型
# - doubao-seed-1-6: 豆包 Seed 快速响应
#
# 【Base URL 注意】
# - OpenAI兼容: https://ark.cn-beijing.volces.com/api/coding/v3 ✅ 消耗Coding Plan额度
# - 警告: https://ark.cn-beijing.volces.com/api/v3 ❌ 产生额外费用！
ARK_API_KEY=your-ark-api-key-here

# 智谱 AI API Key (兜底使用)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here

# 服务器端口 (可选，默认 3000)
PORT=3000

# ==========================================
# OpenClaw 集成配置 (可选)
# ==========================================
# 启用 OpenClaw 任务执行功能
OPENCLAW_ENABLED=true

# OpenClaw 网关 API 地址
OPENCLAW_API=http://127.0.0.1:18789

# OpenClaw API Token
# 从 ~/.openclaw/openclaw.json 获取（gateway.auth.token 字段）
OPENCLAW_TOKEN=your-openclaw-token-here

# OpenClaw 工作区路径
# 注意：将 YourName 替换为你的实际用户名
# Windows: C:\Users\你的用户名\.openclaw\workspace
# Mac/Linux: /Users/你的用户名/.openclaw/workspace
OPENCLAW_WORKSPACE=C:\Users\YourName\.openclaw\workspace

# ==========================================
# 使用说明
# ==========================================
# 1. 复制此文件为 .env
# 2. 填写你的 API Key
# 3. 启动 OpenClaw 网关: openclaw gateway
# 4. 启动小易服务器: node server.js
# 5. 访问: http://localhost:3000/voice.html
# ==========================================
