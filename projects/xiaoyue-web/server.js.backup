    console.log(`🎤 语音版: http://localhost:${PORT}/voice.html`);
    console.log(`🧪 测试页: http://localhost:${PORT}/test.html`);
    console.log(`🔍 调试信息: http://localhost:${PORT}/debug`);
    console.log(`========================================`);
});
